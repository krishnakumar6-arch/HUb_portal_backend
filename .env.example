# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/hubportal
SYNC_DATABASE_URL=postgresql://user:password@host:5432/hubportal

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Google Drive / Sheets ─────────────────────────────────
# Option A: Service Account JSON (recommended for server)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: File ID of the Excel/Sheet on Google Drive
GOOGLE_DRIVE_FILE_ID=your_file_id_here

# ── App ───────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# ── ETL Schedule ──────────────────────────────────────────
ETL_CRON_HOUR=2
ETL_CRON_MINUTE=0
ETL_CRON_TIMEZONE=Asia/Kolkata
